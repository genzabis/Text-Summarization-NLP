# Salin file ini menjadi .env lalu isi nilai-nilainya

# API key untuk Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Konfigurasi server Flask
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=True

# Path dataset IndoSum (relatif terhadap root project)
INDOSUM_DIR=..

# Path checkpoint model Seq2Seq
SEQ2SEQ_CHECKPOINT=models/checkpoints/seq2seq_best.pt
SEQ2SEQ_VOCAB=models/checkpoints/vocab.json
