# Salin file ini menjadi .env lalu isi nilai-nilainya

# API key untuk Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=
GEMINI_MODEL_NAME=

# Konfigurasi server Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=False

# Path dataset IndoSum (pakai /app saat jalan di Docker)
INDOSUM_DIR=/app

# Path checkpoint model Seq2Seq
SEQ2SEQ_CHECKPOINT=/app/models/checkpoints/seq2seq_best.pt
SEQ2SEQ_VOCAB=/app/models/checkpoints/vocab.json
